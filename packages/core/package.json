      "import": "./src/lint/index.ts",
      "types": "./src/lint/index.ts"
    },
    "./compiler": {
      "import": "./src/compiler/index.ts",
      "types": "./src/compiler/index.ts"
    },
    "./runtime": "./dist/hyperframe.runtime.iife.js",
