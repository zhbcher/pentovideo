  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.10.13",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^29.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "esbuild": "^0.25.12",
    "linkedom": "^0.18.12"
  }
