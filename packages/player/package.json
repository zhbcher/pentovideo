{
  "name": "@pentovideo/player",
  "version": "0.5.7",
  "description": "Embeddable web component for PentoVideo compositions",
  "repository": {
    "type": "git",
    "url": "https://github.com/pentovideo/pentovideo",
    "directory": "packages/player"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/pentovideo-player.js",
  "types": "./dist/pentovideo-player.d.ts",
  "exports": {
    ".": {
      "types": "./dist/pentovideo-player.d.ts",
      "script": "./dist/pentovideo-player.global.js",
      "import": "./dist/pentovideo-player.js",
      "require": "./dist/pentovideo-player.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/perf/tsconfig.json",
    "test": "vitest run",
    "perf": "bun run tests/perf/index.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "gsap": "^3.12.5",
    "puppeteer-core": "^24.39.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
